{
  "version": 1,
  "sdk_version": "0.20.0",
  "path": "/mcp",
  "auth": {
    "type": "none"
  },
  "mcp": {
    "server": {
      "name": "our-album-mcp",
      "version": "0.1.0",
      "title": "Our Album"
    },
    "tools": [
      {
        "name": "list_chapters",
        "title": "List album chapters",
        "description": "List all chapters of the private album (title, slug, dates, description). Requires the album passcode.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "passcode": {
              "type": "string",
              "minLength": 1,
              "description": "Album passcode required to unlock the album."
            }
          },
          "required": [
            "passcode"
          ]
        },
        "outputSchema": null
      },
      {
        "name": "get_chapter",
        "title": "Get a chapter with its photos",
        "description": "Fetch one chapter by slug together with its photos (title, caption, taken_at, image URL). Requires the album passcode.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "passcode": {
              "type": "string",
              "minLength": 1,
              "description": "Album passcode required to unlock the album."
            },
            "slug": {
              "type": "string",
              "minLength": 1,
              "description": "Chapter slug, e.g. 'first-coffee'."
            }
          },
          "required": [
            "passcode",
            "slug"
          ]
        },
        "outputSchema": null
      },
      {
        "name": "list_timeline_photos",
        "title": "List timeline photos",
        "description": "List every photo in the album in chronological order by taken_at, including title, caption, and parent chapter. Requires the album passcode.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "passcode": {
              "type": "string",
              "minLength": 1,
              "description": "Album passcode required to unlock the album."
            },
            "limit": {
              "type": "integer",
              "minimum": -9007199254740991,
              "maximum": 9007199254740991,
              "description": "Optional maximum number of photos to return. Leave unset for all."
            }
          },
          "required": [
            "passcode"
          ]
        },
        "outputSchema": null
      }
    ]
  }
}
